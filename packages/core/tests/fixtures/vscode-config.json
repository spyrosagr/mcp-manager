{
  "mcp": {
    "servers": {
      "github": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_vscode_token"
        }
      },
      "web-search": {
        "type": "sse",
        "url": "https://search.example.com/mcp/sse"
      }
    }
  },
  "editor.fontSize": 14,
  "editor.tabSize": 2
}
